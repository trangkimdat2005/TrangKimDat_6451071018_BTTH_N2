# Core Service
PORT=3002
NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=core-service
KAFKA_RAW_EVENTS_TOPIC=facebook-events
KAFKA_COMMANDS_TOPIC=facebook-commands
KAFKA_CONSUMER_GROUP=core-service-group

# AI / OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Circuit Breaker (for OpenAI API)
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=30000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=fb_api_db
DATABASE_USER=fb_api_user
DATABASE_PASSWORD=fb_api_password

# Automation
AUTO_REPLY_GIA=Cam on ban da quan tam! Don gia san pham la XXX VND. Lien he page de biet them chi tiet.
AUTO_REPLY_CAM_ON=Cam on ban da dong hanh cung chung toi! Rat vui khi ban thich san pham. Chao mung ban quay lai lan nua!
AUTO_REPLY_KHEN=Tur on cam on! Chung toi rat vui khi nhan duoc phan hoi tich cuc cua ban.
AUTO_REPLY_KHAC=Chao ban! Cam on ban da binh luan. Chung toi se phan hoi som nhat co the.

# Sentiment-specific replies (Bai 3)
AUTO_REPLY_TICH_CUC=Cam on ban da dong hanh cung shop! Rat vui khi ban hau long, chung toi se con giu chat dang quay lai.
AUTO_REPLY_TIEU_CUC=Rat xin loi vi trai nghiem chua tot. Ben minh se kiem tra va phan hoi lai som nhat co the. Cam on ban da phan hoi!
AUTO_REPLY_TRUNG_TINH=Chao ban! Cam on ban da binh luan. Chung toi se tra loi trong thoi gian som nhat.
