# Retry Service
PORT=3003
NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=retry-service
KAFKA_RETRY_TOPIC=facebook-retry
KAFKA_DEAD_LETTER_TOPIC=facebook-dead-letter
KAFKA_COMMANDS_TOPIC=facebook-commands
KAFKA_CONSUMER_GROUP=retry-service-group

# Retry settings
MAX_RETRIES=5
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_RESET_MS=30000

# Backend API (for retry calls)
BACKEND_API_URL=http://localhost:3000
INTERNAL_API_KEY=retry-service-internal-key-2024

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=fb_api_db
DATABASE_USER=fb_api_user
DATABASE_PASSWORD=fb_api_password
