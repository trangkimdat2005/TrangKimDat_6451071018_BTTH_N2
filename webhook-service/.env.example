# Webhook Service
PORT=3001
NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=webhook-service
KAFKA_RAW_EVENTS_TOPIC=facebook-events
KAFKA_CONSUMER_GROUP=webhook-service-group

# Facebook
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your_verify_token_here

# Database (for rate limiting check)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=fb_api_db
DATABASE_USER=fb_api_user
DATABASE_PASSWORD=fb_api_password

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_EVENTS=20
